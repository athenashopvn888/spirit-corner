# Manager blog login - no real secrets in this file.
MANAGER_BLOG_USERNAME=
# Generate a scrypt hash with:
# node -e "const crypto=require('crypto'); const password='replace-me'; const salt=crypto.randomBytes(16); const hash=crypto.scryptSync(password, salt, 64); console.log('scrypt:'+salt.toString('hex')+':'+hash.toString('hex'))"
MANAGER_BLOG_PASSWORD_HASH=
MANAGER_BLOG_SESSION_SECRET=

