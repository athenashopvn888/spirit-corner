# Manager blog login - no real secrets in this file.
# Preferred multi-user format. Keep usernames and hashes in Vercel/env only.
# Example shape only:
# MANAGER_BLOG_USERS_JSON=[{"username":"manager-user","passwordHash":"scrypt:salt:hash","role":"publisher","stores":["CHC01","SCC01"]},{"username":"admin-user","passwordHash":"scrypt:salt:hash","role":"master_admin","stores":["CHC01","SCC01"]}]
MANAGER_BLOG_USERS_JSON=

# Backwards-compatible single-user fallback. Leave blank when MANAGER_BLOG_USERS_JSON is used.
MANAGER_BLOG_USERNAME=
# Generate a scrypt hash with:
# node -e "const crypto=require('crypto'); const password=process.argv[1]; const salt=crypto.randomBytes(16); const hash=crypto.scryptSync(password, salt, 64); console.log('scrypt:'+salt.toString('hex')+':'+hash.toString('hex'))" "temporary-password"
MANAGER_BLOG_PASSWORD_HASH=
MANAGER_BLOG_SESSION_SECRET=

# Manager blog storage. Leave blank until the approved writable backend is connected.
# Supported current provider: app-script
MANAGER_BLOG_STORAGE_PROVIDER=
MANAGER_BLOG_STORAGE_URL=
MANAGER_BLOG_STORAGE_TOKEN=

# Manager blog storage endpoint contract - names only, no secrets.
# MANAGER_BLOG_STORAGE_PROVIDER currently supports: app-script
# MANAGER_BLOG_STORAGE_URL should point to the approved server-side storage endpoint.
# MANAGER_BLOG_STORAGE_TOKEN is sent only from server-side API/storage helpers as a Bearer token.
# Required JSON actions accepted by the storage endpoint:
# - list via GET ?action=blog&store=<STORE_CODE>&admin=1
# - create via POST { action: "create", ...postFields }
# - update via POST { action: "update", id, ...postFields }
# - publish via POST { action: "publish", id, published: true, ...postFields }
# - unpublish via POST { action: "unpublish", id, published: false, ...postFields }
# - archive via POST { action: "archive", id, archived: true, published: false, ...postFields }
# - delete via POST/DELETE { action: "delete", id, store_code }
# - duplicate is implemented app-side as a create action copied from an existing post.
# Required post fields include: id, title, slug, seo_title, meta_description, h1, content, faq,
# featured_image_url, target_keyword, supporting_keywords, expected_result, manager_notes,
# baseline_query, baseline_note, baseline_screenshot_url, result_7_day_note,
# result_14_day_note, result_28_day_note, gsc_clicks, gsc_impressions, gsc_ctr,
# gsc_position, author, manager_owner, source, experiment_tag, store_code, created_at,
# updated_at, published_at, published, archived.
