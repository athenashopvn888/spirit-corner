# Manager blog login - no real secrets in this file.
# Preferred multi-user format. Keep usernames and hashes in Vercel/env only.
# Example shape only:
# MANAGER_BLOG_USERS_JSON=[{"username":"manager-user","passwordHash":"scrypt:salt:hash","role":"publisher","stores":["CHC01","SCC01"]},{"username":"admin-user","passwordHash":"scrypt:salt:hash","role":"master_admin","stores":["CHC01","SCC01"]}]
MANAGER_BLOG_USERS_JSON=

# Backwards-compatible single-user fallback. Leave blank when MANAGER_BLOG_USERS_JSON is used.
MANAGER_BLOG_USERNAME=
# Generate a scrypt hash with:
# node -e "const crypto=require('crypto'); const password=process.argv[1]; const salt=crypto.randomBytes(16); const hash=crypto.scryptSync(password, salt, 64); console.log('scrypt:'+salt.toString('hex')+':'+hash.toString('hex'))" "temporary-password"
MANAGER_BLOG_PASSWORD_HASH=
MANAGER_BLOG_SESSION_SECRET=

# Manager blog storage. Leave blank until the approved writable backend is connected.
# Supported current provider: app-script
MANAGER_BLOG_STORAGE_PROVIDER=
MANAGER_BLOG_STORAGE_URL=
MANAGER_BLOG_STORAGE_TOKEN=
